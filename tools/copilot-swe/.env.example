# copilot-swe configuration (copy to .env for local `run.sh` testing).
#
# A SINGLE fine-grained (v2) GitHub PAT authenticates everything: the Copilot
# model (needs the "Copilot Requests" account permission, from a Copilot-
# subscribed account) AND all git/gh operations (needs Contents + Pull requests
# write, plus Administration write to create repos).
GITHUB_TOKEN=

# --- Optional ---
# Pin a model (e.g. claude-sonnet-4.6, gpt-5.4); empty => Copilot chooses.
COPILOT_MODEL=
# Override for GitHub Enterprise Server (default https://api.github.com).
GITHUB_API_URL=

# --- Messaging (normally injected by the tool-controller in-cluster) ---
RECIPE_TRANSPORT=stdout
RECIPE_JOB_ID=
RECIPE_CALLBACK_URL=
RECIPE_CALLBACK_SECRET=
RECIPE_CALLBACK_ALLOWED_HOSTS=

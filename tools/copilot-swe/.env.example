# copilot-swe configuration (copy to .env for local `run.sh` testing).
#
# TWO GitHub credentials, on purpose (see src/config.ts / docs/security.md):
#   1. A GitHub App (id + private key) — mints a short-lived installation token
#      used for all git/gh operations. The App install bounds which repos this
#      tool can touch.
#   2. A Copilot-entitled fine-grained PAT — authenticates the Copilot model.

# --- GitHub App (repo/git/PR auth) ---
GITHUB_APP_ID=123456
# Optional: skip installation lookup by pinning the id.
GITHUB_APP_INSTALLATION_ID=
# PEM contents of the App private key. Multi-line is fine; base64 is also accepted.
GITHUB_APP_PRIVATE_KEY=

# --- Copilot model auth ---
# Fine-grained (v2) PAT with the "Copilot Requests" permission, from an account
# with a Copilot subscription. Classic ghp_ tokens are NOT accepted.
COPILOT_GITHUB_TOKEN=

# --- Optional ---
# Pin a model (e.g. claude-sonnet-4.6, gpt-5.4); empty => Copilot chooses.
COPILOT_MODEL=
# Override for GitHub Enterprise Server (default https://api.github.com).
GITHUB_API_URL=

# --- Messaging (normally injected by the tool-controller in-cluster) ---
RECIPE_TRANSPORT=stdout
RECIPE_JOB_ID=
RECIPE_CALLBACK_URL=
RECIPE_CALLBACK_SECRET=
RECIPE_CALLBACK_ALLOWED_HOSTS=

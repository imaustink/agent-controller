# Optional limits (bytes / chars / milliseconds).
# WEB_FETCH_MAX_BYTES=10485760
# WEB_FETCH_MAX_CHARS=20000
# WEB_FETCH_TIMEOUT_MS=15000
# WEB_FETCH_MAX_REDIRECTS=5
# WEB_FETCH_USER_AGENT=

# Optional messaging / transport. See docs/messaging.md for full details.
# RECIPE_TRANSPORT=stdout            # stdout | events | file | callback
# RECIPE_JOB_ID=                     # correlation id (defaults to a random UUID)
# RECIPE_EVENTS_PATH=/tmp/web-fetch-events.ndjson
# RECIPE_CALLBACK_URL=https://parent.internal/hook
# RECIPE_CALLBACK_SECRET=            # enables HMAC-SHA256 signing of callback bodies
# RECIPE_CALLBACK_ALLOWED_HOSTS=parent.internal
# RECIPE_CALLBACK_MAX_RETRIES=3

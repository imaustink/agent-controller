{
  "name": "web-fetch",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-contained subagent container: a URL in, its main page content (Markdown) out.",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "web-fetch": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@controller-agent/messaging": "0.1.0",
    "@mozilla/readability": "^0.6.0",
    "jsdom": "^24.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.16.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^4.0.0"
  }
}

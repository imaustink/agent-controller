# SearXNG target (fixed configuration -- never derived from tool input)
SEARXNG_BASE_URL=http://localhost:8888

# Messaging transport (see ../../docs/messaging.md). NOTE: these are named
# RECIPE_* -- that's core-controller's actual wire protocol for every tool
# (see comment in src/config.ts), not specific to recipes.
RECIPE_TRANSPORT=
RECIPE_JOB_ID=
RECIPE_CALLBACK_URL=
RECIPE_CALLBACK_SECRET=
RECIPE_CALLBACK_ALLOWED_HOSTS=

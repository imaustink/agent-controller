# Mealie publish target (fixed configuration — never derived from tool input)
# MEALIE_API_TOKEN is a long-lived API token, created in the Mealie UI at
# /user/profile/api-tokens (or via POST /api/users/api-tokens).
MEALIE_BASE_URL=https://recipes.kurpuis.com
MEALIE_API_TOKEN=
# Which of Mealie's registered ingredient parsers to use for structuring
# quantity/unit/food (nlp | brute | openai). Defaults to nlp.
MEALIE_INGREDIENT_PARSER=nlp

# Messaging transport (see ../../docs/messaging.md)
RECIPE_TRANSPORT=
RECIPE_JOB_ID=
RECIPE_CALLBACK_URL=
RECIPE_CALLBACK_SECRET=
RECIPE_CALLBACK_ALLOWED_HOSTS=

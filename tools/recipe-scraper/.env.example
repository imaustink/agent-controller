# Required: OpenAI API key used for OCR (vision), audio transcription, and recipe formatting.
OPENAI_API_KEY=sk-...

# Optional: override the OpenAI-compatible base URL.
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional model overrides.
# RECIPE_FORMAT_MODEL=gpt-4o-2024-08-06
# RECIPE_VISION_MODEL=gpt-4o-2024-08-06
# RECIPE_TRANSCRIBE_MODEL=whisper-1

# Optional limits (bytes / chars / milliseconds).
# RECIPE_MAX_TEXT_CHARS=100000
# RECIPE_MAX_IMAGE_BYTES=15728640
# RECIPE_MAX_AUDIO_BYTES=26214400
# RECIPE_NAV_TIMEOUT_MS=30000
# RECIPE_SUBPROCESS_TIMEOUT_MS=180000
# RECIPE_FETCH_TIMEOUT_MS=30000
# RECIPE_MAX_REDIRECTS=5

# Optional (video): path to a mounted read-only Netscape cookies file for
# login-gated videos. Mount it, e.g. -v "$PWD/cookies.txt:/cookies.txt:ro".
# RECIPE_YTDLP_COOKIES=/cookies.txt

# Optional messaging / transport. See docs/messaging.md for full details.
# RECIPE_TRANSPORT=stdout            # stdout | events | file | callback
# RECIPE_JOB_ID=                     # correlation id (defaults to a random UUID)
# RECIPE_EVENTS_PATH=/tmp/recipe-events.ndjson
# RECIPE_CALLBACK_URL=https://parent.internal/hook
# RECIPE_CALLBACK_SECRET=            # enables HMAC-SHA256 signing of callback bodies
# RECIPE_CALLBACK_ALLOWED_HOSTS=parent.internal
# RECIPE_CALLBACK_MAX_RETRIES=3

{
  "name": "recipe-scraper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-contained subagent container: arbitrary URL in, normalized recipe JSON out.",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "recipe-scraper": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@controller-agent/messaging": "0.1.0",
    "jsdom": "^24.1.3",
    "openai": "^6.45.0",
    "playwright": "1.61.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.16.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^4.0.0"
  }
}

# GitHub token gh authenticates with. In production this is injected
# per-invocation as the CALLING user's own identity-linked token via
# ToolRunSpec.secretEnv (ADR 0022/0027) -- never a static value baked in
# here. For local development, use a fine-grained PAT scoped to just the
# repos you want to test against.
GITHUB_TOKEN=
# Fixed GitHub API host (only relevant for GitHub Enterprise Server).
GH_HOST=github.com

# Messaging transport (see ../../docs/messaging.md)
RECIPE_TRANSPORT=
RECIPE_JOB_ID=
RECIPE_CALLBACK_URL=
RECIPE_CALLBACK_SECRET=
RECIPE_CALLBACK_ALLOWED_HOSTS=

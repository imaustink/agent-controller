{
  "name": "github",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-contained subagent container: a single allowlisted gh CLI command in, gh's own output out, authenticated as the calling user's own delegated GitHub token.",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "github": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@controller-agent/messaging": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^4.0.0"
  }
}

# Fetched Helm chart dependencies (run `helm dependency build` to refetch);
# Chart.lock IS committed to pin versions, the downloaded .tgz artifacts are not.
# Recursive so the umbrella chart's nested subchart deps are covered too
# (e.g. charts/recipe-agent/charts/agent-orchestrator/charts/qdrant-*.tgz).
charts/**/charts/*.tgz

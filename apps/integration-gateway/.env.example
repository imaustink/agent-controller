# Required for HTTP callback mode
GATEWAY_CALLBACK_BASE_URL=http://localhost:8091
GATEWAY_CALLBACK_SECRET=
GATEWAY_CALLBACK_SECRET_REF_NAME=

# Optional (defaults shown)
# GATEWAY_NAMESPACE=default
# GATEWAY_CRD_GROUP=core.controller-agent.dev
# GATEWAY_CRD_VERSION=v1alpha1
# GATEWAY_HTTP_PORT=8090
# GATEWAY_CALLBACK_PORT=8091
# GATEWAY_CALLBACK_SECRET_REF_KEY=secret
# GATEWAY_RUN_TIMEOUT_SECONDS=600

# DEV/TEST ONLY — see src/rbac/static-identity-resolver.ts. JSON map of
# bearer token -> { subject, roles }. Never use this in production.
# GATEWAY_STATIC_IDENTITIES={"dev-token":{"subject":"dev","roles":["reader"]}}
# Pass the token per-request instead: curl -H 'authorization: ******' ...

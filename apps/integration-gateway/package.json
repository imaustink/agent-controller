{
  "name": "integration-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Direct catalog-driven HTTP gateway for launching ToolRun and AgentRun custom resources.",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "integration-gateway": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@controller-agent/messaging": "0.1.0",
    "@kubernetes/client-node": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^4.0.0"
  }
}

# Required
OPENAI_API_KEY=
AGENT_CALLBACK_SECRET=

# Optional (defaults shown)
# AGENT_NAMESPACE=default
# AGENT_NATS_URL=nats://localhost:4222
# AGENT_NATS_SUBJECT_PREFIX=agent
# AGENT_QDRANT_URL=http://localhost:6333
# AGENT_QDRANT_API_KEY=
# AGENT_QDRANT_COLLECTION=tools
# AGENT_QDRANT_VECTOR_SIZE=1536
# AGENT_QDRANT_SKILLS_COLLECTION=skills
# AGENT_EMBEDDING_MODEL=text-embedding-3-small
# AGENT_SELECTION_MODEL=gpt-4o-2024-08-06
# AGENT_CALLBACK_PORT=8080
# AGENT_CALLBACK_BASE_URL=http://localhost:8080
# AGENT_HTTP_PORT=8081
# AGENT_SKILL_TOP_K=3
# Conversation-session store (ADR 0012): how long a chat's active skill is
# remembered between turns (sliding idle TTL, seconds) and the max number of
# concurrent sessions (least-recently-updated evicted first).
# AGENT_SESSION_TTL_SECONDS=1800
# AGENT_SESSION_MAX_ENTRIES=1000

# Which IdentityResolver to build: "static" (default, dev/test only) or
# "oidc" (verify caller bearer tokens as JWTs against a real IdP).
# AGENT_IDENTITY_RESOLVER=static

# DEV/TEST ONLY, used when AGENT_IDENTITY_RESOLVER=static (or unset) — see
# src/rbac/static-identity-resolver.ts. JSON map of bearer token ->
# { subject, roles }. Never use this in production.
# AGENT_STATIC_IDENTITIES={"dev-token":{"subject":"dev","roles":["reader"]}}
# Pass the token per-request instead: curl -H 'authorization: Bearer dev-token' ...

# Used when AGENT_IDENTITY_RESOLVER=oidc — see
# src/rbac/oidc-identity-resolver.ts. AGENT_OIDC_ISSUER and
# AGENT_OIDC_JWKS_URI are required; AGENT_OIDC_AUDIENCE is optional
# (unset skips audience verification); AGENT_OIDC_ROLES_CLAIM defaults to
# "roles" (dot-path, e.g. "realm_access.roles" for Keycloak).
# AGENT_OIDC_ISSUER=https://issuer.example.com
# AGENT_OIDC_JWKS_URI=https://issuer.example.com/.well-known/jwks.json
# AGENT_OIDC_AUDIENCE=agent-orchestrator
# AGENT_OIDC_ROLES_CLAIM=roles

